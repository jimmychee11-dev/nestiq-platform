{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "crons": [
    { "path": "/api/cron/run-tasks", "schedule": "* * * * *" }
  ],
  "functions": {
    "app/api/cron/run-tasks/route.ts": { "maxDuration": 300 },
    "app/api/companies/[id]/stream/route.ts": { "maxDuration": 300 },
    "app/api/companies/route.ts": { "maxDuration": 180 },
    "app/api/tasks/[id]/alternatives/route.ts": { "maxDuration": 60 }
  }
}
