# --- Core ---
DATABASE_URL="postgresql://nestiq:nestiq@localhost:5432/nestiq?schema=public"
REDIS_URL="redis://localhost:6379"
ANTHROPIC_API_KEY="sk-ant-..."

# --- Agent engine ---
# Default model for all agents unless overridden per-agent in the DB.
AGENT_MODEL="claude-opus-4-8"
# Hard ceiling on model-call turns inside a single task loop.
AGENT_MAX_TURNS="24"
# Worker concurrency (tasks processed in parallel per worker process).
WORKER_CONCURRENCY="4"

# --- MCP servers (enable by setting the env vars; unset = server skipped) ---
# Filesystem MCP — sandbox root the Engineering agent may read/write.
MCP_FS_ROOT="C:/nestiq-sandbox"
# Slack notifications (https://github.com/modelcontextprotocol/servers)
SLACK_BOT_TOKEN=""
SLACK_TEAM_ID=""
# Resend cold-email MCP
RESEND_API_KEY=""
# GitHub MCP (deploys, PRs)
GITHUB_PERSONAL_ACCESS_TOKEN=""

# --- Security ---
# Set a strong secret to enable dashboard authentication. Leave empty to disable (dev only).
# Example: DASHBOARD_TOKEN="nestiq_change_me_to_a_strong_secret_$(openssl rand -hex 16)"
DASHBOARD_TOKEN=""
