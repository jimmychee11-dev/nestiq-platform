{
  "name": "nestiq-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx --env-file=.env src/worker.ts",
    "seed": "tsx --env-file=.env prisma/seed.ts",
    "db:push": "prisma db push --accept-data-loss --skip-generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "typecheck": "tsc --noEmit",
    "health": "curl -sf http://localhost:3000/api/health || echo 'Stack down'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@prisma/client": "^6.8.0",
    "bullmq": "^5.34.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.469.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.8.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
